# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/policy_qa
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/policy_qa

# JWT
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM Provider: dashscope | openai | qianfan
LLM_PROVIDER=dashscope

# DashScope (阿里云通义千问)
DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_MODEL=qwen-plus

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o

# Qianfan (百度千帆)
QIANFAN_API_KEY=your-bce-api-key
QIANFAN_MODEL=deepseek-v3.1-250821
QIANFAN_API_URL=https://qianfan.baidubce.com/v2

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
